# Block PHP execution in uploads directory
Options -Indexes -ExecCGI

<FilesMatch "\.php[0-9]?$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.phtml$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow only image files
<FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
    Order allow,deny
    Allow from all
</FilesMatch>

AddType text/plain .php .phtml .php3 .php4 .php5 .php7 .php8
